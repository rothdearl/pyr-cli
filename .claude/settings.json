{
    "$schema": "https://json.schemastore.org/claude-code-settings.json",
    "permissions": {
        "allow": [
            "Bash(git -C * diff --staged*)",
            "Bash(git diff --staged*)",
            "Bash(npm run compile)",
            "Bash(npm run lint)",
            "Bash(npm run test:report)",
            "Bash(npm run test*)",
            "WebFetch",
            "WebSearch"
        ],
        "deny": [
            "Bash(git clean -f*)",
            "Bash(git push --force*)",
            "Bash(git reset --hard*)",
            "Bash(rm -rf*)",
            "Read(.env.local)",
            "Read(.env)"
        ]
    }
}
